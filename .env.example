# Geekspace environment configuration.
# Copy to .env.local (gitignored) and fill in. Everything here is optional unless
# noted: the app runs with sane defaults and degrades gracefully when a given
# integration isn't configured.

# --- Convex (local backend) -------------------------------------------------
# Written automatically by `npx convex dev`; the packaged app manages its own.
CONVEX_DEPLOYMENT=anonymous:anonymous-agent
VITE_CONVEX_URL=http://127.0.0.1:3210
VITE_CONVEX_SITE_URL=http://127.0.0.1:3211

# --- Local agent (Ollama) lane ----------------------------------------------
# Model that drives the local ARCHITECT lane (defaults to a qwen3-coder build).
# GEEKSPACE_LOCAL_MODEL=qwen3-coder
# GEEKSPACE_LOCAL_NUM_CTX=32768

# --- Enterprise Search: ASTGL knowledge server (optional) -------------------
# Absolute path to the built mcp-astgl-knowledge stdio server (…/dist/index.js).
# Leave unset and the Knowledge page / ⌘K knowledge results stay offline.
# GEEKSPACE_KNOWLEDGE_SERVER=/absolute/path/to/mcp-astgl-knowledge/dist/index.js
# Optional higher daily quota for that server (anonymous = 50 queries/day).
# ASTGL_API_KEY=
# Node binary used to spawn the knowledge server (native-module ABI). Auto-
# detected from PATH / Homebrew; override only if detection fails.
# GEEKSPACE_NODE=/opt/homebrew/bin/node

# --- Claude agent lane via ClaudeClaw (optional) ----------------------------
# Bearer token for the ClaudeClaw daemon that backs the hosted ARCHITECT lane.
# CLAUDECLAW_TOKEN=
