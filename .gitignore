# Dependencies
node_modules/

# Build output
dist/
release/
build/icon.iconset/
# Pre-baked packaging artifacts (generated by `npm run prebake`)
build/convex-seed/
build/convex-local-backend
build/geekspace-mcp.mjs

# Environment — Convex deployment URL lives here; never commit env files
.env
.env.local
.env.*.local

# Convex local artifacts
.convex/

# Logs
*.log
npm-debug.log*

# Test coverage
coverage/

# macOS
.DS_Store

# Editor
.idea/
*.swp
tsconfig.tsbuildinfo

# Local Claude Code settings (personal, machine-specific)
.claude/settings.local.json

# Article assets — heavy media stays local. Screenshots are regenerated from the
# demo workspace before publishing; do not commit captures of a live workspace.
docs/article-assets/*.mp4
docs/article-assets/*.png
docs/article-assets/_replaced-web-captures/
