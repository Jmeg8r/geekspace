{
  "name": "geekspace",
  "productName": "Geekspace",
  "version": "0.1.0",
  "description": "Your workspace, As The Geek Learns it — Notion-style pages, databases, and a calendar that schedules itself.",
  "author": "James F. Cruce",
  "license": "MIT",
  "private": true,
  "main": "electron/main.mjs",
  "scripts": {
    "backend": "convex dev",
    "frontend": "vite",
    "electron": "wait-on tcp:127.0.0.1:5173 && VITE_DEV_SERVER_URL=http://localhost:5173 electron .",
    "dev": "concurrently -k -n convex,vite,app -c blue,magenta,yellow \"npm:backend\" \"npm:frontend\" \"npm:electron\"",
    "dev:web": "concurrently -k -n convex,vite -c blue,magenta \"npm:backend\" \"npm:frontend\"",
    "seed": "convex run seed:seedWorkspace",
    "build": "tsc -b && vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "package": "npm run build && npm run prebake && electron-builder --mac",
    "prebake": "node scripts/prebake-seed.mjs",
    "migrate:local-data": "node scripts/migrate-local-data.mjs",
    "deploy:local": "node scripts/deploy-local.mjs",
    "verify": "tsc -b --noEmit && vitest run"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.172",
    "@blocknote/core": "^0.51.4",
    "@blocknote/mantine": "^0.51.4",
    "@blocknote/react": "^0.51.4",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@floating-ui/react": "^0.27.0",
    "@mantine/core": "^8.3.11",
    "@mantine/hooks": "^8.3.11",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "convex": "^1.41.0",
    "date-fns": "^4.1.0",
    "lucide-react": "^1.17.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^24.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.0.0",
    "concurrently": "^9.0.0",
    "electron": "^42.0.0",
    "electron-builder": "^26.0.0",
    "tailwindcss": "^4.3.0",
    "typescript": "^5.9.0",
    "vite": "^7.1.0",
    "vitest": "^4.1.0",
    "wait-on": "^8.0.0"
  },
  "build": {
    "appId": "com.astgl.geekspace",
    "productName": "Geekspace",
    "directories": {
      "buildResources": "build",
      "output": "release"
    },
    "files": [
      "dist/**",
      "electron/**",
      "package.json"
    ],
    "extraResources": [
      { "from": "build/convex-local-backend", "to": "convex-local-backend" },
      { "from": "build/convex-seed", "to": "convex-seed" },
      { "from": "build/geekspace-mcp.mjs", "to": "geekspace-mcp.mjs" }
    ],
    "afterPack": "scripts/afterPack.cjs",
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "build/icon.icns",
      "extendInfo": {
        "NSAppleEventsUsageDescription": "Geekspace reads your macOS Calendar and Mail to show events and messages, and to auto-schedule work around your appointments.",
        "NSMicrophoneUsageDescription": "Geekspace records meeting audio so it can transcribe and summarize your meetings — entirely on this Mac."
      }
    }
  }
}
